{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clipper.dev/schemas/appstore_creatives/creative_manifest/v0.1",
  "title": "App Store Creatives Creative Manifest (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "meta", "inputs", "storyboard", "experiment"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "clipper.appstore_creatives.manifest.v0.1"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "createdAt": { "type": ["string", "null"], "format": "date-time" },
        "notes": { "type": ["string", "null"] }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producerCatalog"],
      "properties": {
        "producerCatalog": {
          "type": "string",
          "minLength": 1,
          "description": "Path (or logical ref) to a producer evidence catalog JSON. Resolved by tooling."
        }
      }
    },
    "style": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "styleId": { "type": ["string", "null"], "minLength": 1 },
        "overrides": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "description": "Freeform overrides for the selected style pack (fonts/colors/backgrounds)."
        }
      }
    },
    "storyboard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["screenshots", "videos"],
      "properties": {
        "screenshots": {
          "type": "array",
          "items": { "$ref": "#/$defs/ScreenshotSlide" }
        },
        "videos": {
          "type": "array",
          "items": { "$ref": "#/$defs/VideoProgram" }
        }
      }
    },
    "experiment": { "$ref": "#/$defs/ExperimentSpec" }
  },
  "$defs": {
    "LocaleSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locale"],
      "properties": {
        "locale": { "type": "string", "minLength": 1 },
        "storefront": { "type": ["string", "null"] },
        "language": { "type": ["string", "null"] }
      }
    },
    "CopyByLocale": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "subtitle": { "type": ["string", "null"] }
        }
      }
    },
    "ScreenshotSlide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "archetype", "messageRole", "evidenceId", "copy"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "archetype": {
          "type": "string",
          "enum": ["BillboardHero", "Mechanism", "OutputProof", "Trust", "WorkflowFit", "BeforeAfter"]
        },
        "messageRole": {
          "type": "string",
          "enum": ["Promise", "Mechanism", "Proof", "DeRisk", "Fit", "Handoff", "Delight"]
        },
        "evidenceId": {
          "type": "string",
          "minLength": 1,
          "description": "Resolved via producer evidence catalog."
        },
        "copy": { "$ref": "#/$defs/CopyByLocale" },
        "callouts": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["elementId"],
            "properties": {
              "elementId": { "type": "string", "minLength": 1 },
              "zoom": { "type": ["number", "null"], "exclusiveMinimum": 0 },
              "position": {
                "type": ["string", "null"],
                "enum": ["topLeft", "topRight", "bottomLeft", "bottomRight", null]
              }
            }
          }
        }
      }
    },
    "VideoSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segmentId", "evidenceId"],
      "properties": {
        "segmentId": { "type": "string", "minLength": 1 },
        "evidenceId": { "type": "string", "minLength": 1 },
        "intent": {
          "type": ["string", "null"],
          "enum": ["mechanism", "proof", "trust", "workflow", "handoff", null]
        }
      }
    },
    "ChapterCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["afterSegmentId", "seconds", "copy"],
      "properties": {
        "afterSegmentId": { "type": "string", "minLength": 1 },
        "seconds": { "type": "number", "exclusiveMinimum": 0 },
        "copy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title"],
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "subtitle": { "type": ["string", "null"] }
          }
        }
      }
    },
    "VideoProgram": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "segments"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mode": {
          "type": "string",
          "enum": ["editorial_proof_loop", "tutorial_quickstart", "demo_fullscale"]
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/VideoSegment" }
        },
        "chapterCards": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/ChapterCard" }
        },
        "callouts": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "tapPulseEnabled": { "type": ["boolean", "null"] },
            "rippleEnabled": { "type": ["boolean", "null"] },
            "tapGuideEnabled": { "type": ["boolean", "null"] },
            "density": { "type": ["string", "null"], "enum": ["low", "medium", "high", null] }
          }
        }
      }
    },
    "ExperimentSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "matrix"],
      "properties": {
        "kind": { "type": "string", "enum": ["PPO", "CPP"] },
        "hypothesis": { "type": ["string", "null"] },
        "locales": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/LocaleSpec" }
        },
        "devices": {
          "type": ["array", "null"],
          "items": { "type": "string", "minLength": 1 }
        },
        "matrix": {
          "type": "string",
          "minLength": 1,
          "description": "Path (or logical ref) to an Experiment Matrix JSON."
        }
      }
    }
  }
}

