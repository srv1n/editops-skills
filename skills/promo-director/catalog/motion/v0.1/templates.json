    {
      "id": "alpha.lower_third.modern_dark.v1",
      "title": "Lower third: modern (dark)",
      "description": "Pre-rendered alpha overlay lower third. Orchestrator copies the file into the run dir and composites it via overlay video_clip.",
      "backend": "alpha_overlay_video",
      "tags": ["lower_third", "alpha_overlay", "tier:nice"],
      "output": { "asset_type": "alpha_video", "width": 1080, "height": 1920, "fps": 60 },
      "source": {
        "type": "file",
        "path": "internal_assets/alpha_overlays/alpha.lower_third.modern_dark.v1/alpha.lower_third.modern_dark.v1_1080x1920_60fps_prores4444.mov",
        "license_hint": "Internal-only use; do not redistribute template source files."
      },
      "params_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "variant": { "type": "string", "enum": ["dark"] }
        }
      }
    },
