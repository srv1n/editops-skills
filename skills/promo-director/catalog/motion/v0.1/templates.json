      "id": "gen.remotion.slide_scene.v1",
      "title": "Generated: slide scene (Remotion)",
      "description": "Procedural slide scene (title/body/image) rendered to alpha overlay for ClipOps compositing.",
      "backend": "generated_overlay",
      "tags": ["remotion", "slides", "generated_overlay"],
      "output": { "asset_type": "alpha_video", "width": 1080, "height": 1920, "fps": 60 },
      "generator": {
        "type": "remotion",
        "entrypoint": "remotion_overlays/src/index.ts",
        "command_hint": "Render the Remotion composition 'SlideScene' with props (title/body/image_path) and output ProRes 4444 w/ alpha."
      },
      "params_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 60 },
          "body": { "type": "string", "maxLength": 220 },
          "image_path": { "type": "string" }
        }
