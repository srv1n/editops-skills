          "values": { "type": "array", "items": { "type": "number" }, "maxItems": 12 },
          "callout_label": { "type": "string", "maxLength": 40 }
        }
      }
    },
    {
      "id": "gen.remotion.map_route_draw.v1",
      "title": "Generated: map route draw (Remotion)",
      "description": "Route draw-on over a static map image with a moving dot and waypoint labels.",
      "backend": "generated_overlay",
      "tags": ["remotion", "map", "route", "generated_overlay"],
      "output": { "asset_type": "alpha_video", "width": 1080, "height": 1920, "fps": 60 },
      "generator": {
        "type": "remotion",
        "entrypoint": "remotion_overlays/src/index.ts",
        "command_hint": "Render the Remotion composition 'MapRouteDraw' with props (map_image_path/path_points) and output ProRes 4444 w/ alpha."
      },
      "params_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["map_image_path", "path_points"],
        "properties": {
          "map_image_path": { "type": "string", "minLength": 1 },
          "path_points": {
            "type": "array",
            "minItems": 2,
            "maxItems": 200,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          }
        }
      }
    },
    {
      "id": "gen.maplibre.cinematic_route.v1",
      "title": "Generated: cinematic map route (MapLibre)",
      "description": "Deterministic, time-sliced headless MapLibre render: camera moves + route draw + moving marker.",
      "backend": "generated_overlay",
      "tags": ["maplibre", "map", "route", "generated_overlay"],
      "output": { "asset_type": "alpha_video", "width": 1080, "height": 1920, "fps": 60 },
      "generator": {
        "type": "maplibre",
        "command_hint": "Use tools/maplibre_cinematic_render.py to export a frame-perfect overlay video (ProRes 4444)."
      },
      "params_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["route_lng_lat"],
        "properties": {
          "route_lng_lat": {
            "type": "array",
            "minItems": 2,
            "maxItems": 400,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          },
          "duration_sec": { "type": "number", "minimum": 0.5, "maximum": 60, "default": 6.0 },
          "style_url": { "type": "string", "minLength": 1, "default": "https://demotiles.maplibre.org/style.json" },
          "line_color": { "type": "string", "minLength": 1, "default": "#00E5FF" },
          "line_width": { "type": "number", "minimum": 1, "maximum": 24, "default": 8.0 },
          "marker_color": { "type": "string", "minLength": 1, "default": "#FFFFFF" },
          "zoom": { "type": "number", "minimum": 0, "maximum": 22, "default": 4.0 },
          "pitch": { "type": "number", "minimum": 0, "maximum": 85, "default": 45.0 },
          "bearing": { "type": "number", "minimum": -180, "maximum": 180, "default": 0.0 }
        }
      }
