      "params_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "signal": { "type": "string", "minLength": 1 },
          "signals": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
