{
  "schema": "clipper.motion_template_catalog.v0.1",
  "version": "0.1",
  "meta": {
    "purpose": "Allowlisted templates building blocks for LLM-driven workflows",
    "notes": "Alpha overlays are referenced by ID and copied into run dirs by the orchestrator. File paths here are placeholders for internal asset storage."
  },
  "templates": [
    {
      "id": "clipops.captions.word_highlight.v1",
      "title": "Captions: word highlight",
      "description": "ClipOps-native captions item using word-level highlighting.",
      "backend": "clipops_native",
      "tags": ["captions", "baseline", "readability", "tier:fast"],
      "clipops": { "kind": "captions", "preset": "word_highlight" },
      "params_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "style_ref": { "type": "string" },
          "lookahead_ms": { "type": "integer", "minimum": 0, "maximum": 200, "default": 80 }
        }
      }
    },
    {
      "id": "clipops.captions.word_highlight.behind_matte.v1",
      "title": "Captions: word highlight (behind matte)",
      "description": "ClipOps-native captions with word-level highlighting, occluded by a matte sequence (text behind subject). Requires a matte_sequence asset (default id: subject).",
      "backend": "clipops_native",
      "tags": ["captions", "matte", "occlusion", "tier:premium"],
      "clipops": { "kind": "captions", "preset": "word_highlight_behind_matte" },
      "params_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "style_ref": { "type": "string" },
          "lookahead_ms": { "type": "integer", "minimum": 0, "maximum": 200, "default": 80 },
          "matte_asset": { "type": "string", "minLength": 1, "maxLength": 64, "default": "subject" }
        }
      }
    },
    {
      "id": "clipops.card.title_subtitle.editorial.v1",
      "title": "Card: editorial title+subtitle",
      "description": "ClipOps-native card item with title+subtitle styling from brand kit.",
      "backend": "clipops_native",
      "tags": ["card", "chapter", "editorial", "tier:fast"],
      "clipops": { "kind": "card", "preset": "title_subtitle" },
      "params_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 60 },
          "subtitle": { "type": "string", "maxLength": 90 },
          "bg_color_ref": { "type": "string" }
        }
      }
    },
    {
