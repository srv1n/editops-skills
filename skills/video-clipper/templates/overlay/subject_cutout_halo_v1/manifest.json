{
  "id": "subject_cutout_halo_v1",
  "version": "1",
  "description": "Background replacement (blur/solid/image/greenscreen) + subject cutout + halo, then kinetic captions.",
  "required_signals": ["words"],
  "optional_signals": ["mattes", "faces"],
  "params_schema": {
    "bg_mode": "blur|solid|image|video|greenscreen",
    "bg_blur_px": "number",
    "bg_color": "[number,number,number,number]",
    "bg_image_path": "string",
    "bg_image_fit": "cover|contain",
    "bg_video_path": "string",
    "bg_video_fit": "cover|contain",
    "bg_video_start_sec": "number",
    "bg_video_looped": "boolean",
    "halo_enabled": "boolean",
    "halo_color": "[number,number,number,number]",
    "halo_opacity": "number",
    "halo_spread_px": "number",
    "halo_blur_px": "number",
    "cutout_opacity": "number",
    "cutout_feather_px": "number",
    "cutout_threshold_low": "number",
    "cutout_threshold_high": "number",
    "lightwrap_enabled": "boolean",
    "lightwrap_strength": "number",
    "lightwrap_spread_px": "number",
    "lightwrap_blur_px": "number",
    "title_text": "string",
    "title_slot": "top_left|top_center|top_right|center|bottom_left|bottom_center|bottom_right",
    "title_anchor": "[number,number] (0..1)",
    "title_position_px": "[number,number] (absolute pixels; overrides placement)",
    "title_position_norm": "[number,number] (0..1; overrides placement)",
    "title_font_role": "headline|caption|nametag",
    "title_font_size_px": "number",
    "title_style_id": "string (brand style id)",
    "title_rotation_deg": "number",
    "title_scale": "number",
    "title_opacity": "number",
    "title_blend_mode": "normal|multiply",
    "title_occlude_by_matte": "boolean",
    "icons": "[{id,path,size_px,slot,anchor,rotation_deg,scale,blend_mode,opacity,occlude_by_matte}]"
  }
}
