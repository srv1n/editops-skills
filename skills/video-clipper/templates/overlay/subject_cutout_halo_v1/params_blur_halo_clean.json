{
  "bg_mode": "blur",
  "bg_blur_px": 12,

  "halo_enabled": true,
  "halo_color": [1.0, 1.0, 1.0, 1.0],
  "halo_opacity": 0.65,
  "halo_spread_px": 8,
  "halo_blur_px": 6,

  "cutout_opacity": 1.0,
  "cutout_feather_px": 3.0,
  "cutout_threshold_low": 0.05,
  "cutout_threshold_high": 0.95,

  "lightwrap_enabled": true,
  "lightwrap_strength": 0.25,
  "lightwrap_spread_px": 8,
  "lightwrap_blur_px": 8,

  "position": "bottom",
  "avoid_faces": true,
  "auto_place_by_matte": true,
  "occlude_by_matte": true,

  "plate": false,
  "underline": false,

  "safe_margin_px": 90,
  "autofit_min_scale": 0.90,
  "autofit_max_scale": 0.95,
  "autofit_quantize_step": 0.02,
  "enforce_min_scale_split": true,
  "font_role": "caption",
  "font_size_px": 150,
  "bounce_amount": 0.12,
  "show_all": true,
  "group_max_words": 7,
  "group_max_chars": 40,
  "group_max_duration_sec": 2.8,
  "group_min_words": 3,
  "group_min_duration_sec": 0.75,
  "merge_max_gap_sec": 0.18,
  "gap_break_sec": 0.55,
  "pre_roll_sec": 0.0,
  "post_roll_sec": 0.12,
  "max_lines": 2,
  "window_max_words": 7
}
