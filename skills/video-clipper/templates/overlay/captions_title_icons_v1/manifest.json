{
  "id": "captions_title_icons_v1",
  "version": "1",
  "description": "Kinetic captions plus optional title + PNG/SVG icon layers (no background replacement).",
  "required_signals": ["words"],
  "optional_signals": ["faces", "mattes"],
  "params_schema": {
    "caption_text_fallback": "string",
    "position": "top|center|bottom",
    "avoid_faces": "boolean",
    "placement": "stable_center|per_word_center",
    "plate": "boolean",
    "underline": "boolean",
    "underline_ms": "number",
    "occlude_by_matte": "boolean",
    "safe_margin_px": "number",
    "safe_zone_px": "{left_px,top_px,right_px,bottom_px}",
    "autofit_min_scale": "number",
    "autofit_max_scale": "number",
    "autofit_quantize_step": "number",
    "enforce_min_scale_split": "boolean",
    "font_role": "caption|headline",
    "font_size_px": "number",
    "bounce_amount": "number",
    "show_all": "boolean",
    "group_max_words": "number",
    "group_max_chars": "number",
    "group_max_duration_sec": "number",
    "gap_break_sec": "number",
    "pre_roll_sec": "number",
    "post_roll_sec": "number",
    "max_lines": "number",
    "window_max_words": "number",
    "title_text": "string",
    "title_slot": "top_left|top_center|top_right",
    "title_avoid_faces": "boolean",
    "title_font_role": "headline|caption",
    "title_font_size_px": "number",
    "title_style_id": "string",
    "title_autofit_min_scale": "number",
    "title_autofit_quantize_step": "number",
    "icons": "array[{id,path,size_px:[w,h],slot,anchor:[x,y],opacity,rotation_deg,scale,fit,blend_mode}]"
  }
}
