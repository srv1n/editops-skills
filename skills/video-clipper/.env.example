GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_huggingface_token_here

# Optional: RunPod automation (create/stop matte-service pods programmatically)
RUNPOD_API_KEY=

# Optional: ClipOps matte remote service (for premium effects like "text behind subject")
CLIPOPS_MATTES_REMOTE_PROVIDER=http
CLIPOPS_MATTES_REMOTE_URL=http://127.0.0.1:8000/mattes
CLIPOPS_MATTES_REMOTE_TOKEN=
CLIPOPS_MATTES_REMOTE_ALGO=matanyone
CLIPOPS_MATTES_REMOTE_PROMPT=person
CLIPOPS_MATTES_REMOTE_DEVICE=cuda
CLIPOPS_MATTES_REMOTE_MODEL_ID=
CLIPOPS_MATTES_REMOTE_SAMPLE_FPS=5.0
CLIPOPS_MATTES_REMOTE_THRESHOLD=0.5
CLIPOPS_MATTES_REMOTE_MATANYONE_WARMUP=10
CLIPOPS_MATTES_REMOTE_MATANYONE_ERODE=10
CLIPOPS_MATTES_REMOTE_MATANYONE_DILATE=10
CLIPOPS_MATTES_REMOTE_MATANYONE_MAX_SIZE=-1
