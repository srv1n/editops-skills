{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clipops.dev/schemas/clipops/brand_kit/v0.4",
  "title": "ClipOps Brand Kit (v0.4)",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "fonts", "colors", "styles"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "scale": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "ref_height_px": { "type": "integer", "minimum": 1 }
      }
    },
    "fonts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/FontSpec" }
    },
    "colors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/ColorRgba" }
    },
    "styles": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/TextStyle" }
    },
    "callouts": {
      "oneOf": [{ "$ref": "#/$defs/CalloutsStyle" }, { "type": "null" }]
    },
    "layout": {
      "oneOf": [{ "$ref": "#/$defs/BrandLayout" }, { "type": "null" }]
    }
  },
  "$defs": {
    "FontSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size_px"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "size_px": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "ColorRgba": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "StrokeStyle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["color", "width_px"],
      "properties": {
        "color": { "$ref": "#/$defs/ColorRgba" },
        "width_px": { "type": "integer" }
      }
    },
    "ShadowStyle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["color", "offset", "blur_px"],
      "properties": {
        "color": { "$ref": "#/$defs/ColorRgba" },
        "offset": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2
        },
        "blur_px": { "type": "integer", "minimum": 0 }
      }
    },
    "TextStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fill": { "$ref": "#/$defs/ColorRgba" },
        "stroke": { "$ref": "#/$defs/StrokeStyle" },
        "shadow": { "$ref": "#/$defs/ShadowStyle" }
      }
    },
    "CalloutsStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ripple": { "$ref": "#/$defs/CalloutsRippleStyle" },
        "tap_guide": { "$ref": "#/$defs/CalloutsTapGuideStyle" }
      }
    },
    "CalloutsRippleStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 },
        "lead_ms": { "type": "integer", "minimum": 0 },
        "outline_post_ms": { "type": "integer", "minimum": 0 },
        "color_ref": { "type": "string", "minLength": 1 },
        "radius_px": { "type": "number", "exclusiveMinimum": 0 },
        "stroke_px": { "type": "number", "exclusiveMinimum": 0 },
        "outline_color_ref": { "type": "string", "minLength": 1 },
        "outline_stroke_px": { "type": "number", "exclusiveMinimum": 0 },
        "outline_padding_px": { "type": "number", "minimum": 0 }
      }
    },
    "CalloutsTapGuideStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ripple_enabled": { "type": "boolean" },
        "outline_enabled": { "type": "boolean" },
        "focus_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "arrow": { "$ref": "#/$defs/CalloutsTapGuideArrowStyle" },
        "label": { "$ref": "#/$defs/CalloutsTapGuideLabelStyle" }
      }
    },
    "CalloutsTapGuideArrowStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lead_ms": { "type": "integer", "minimum": 0 },
        "draw_ms": { "type": "integer", "minimum": 0 },
        "hold_ms": { "type": "integer", "minimum": 0 },
        "fade_out_ms": { "type": "integer", "minimum": 0 },
        "color_ref": { "type": "string", "minLength": 1 },
        "stroke_px": { "type": "number", "exclusiveMinimum": 0 },
        "curve": { "$ref": "#/$defs/CalloutsTapGuideArrowCurveStyle" },
        "arrowhead": { "$ref": "#/$defs/CalloutsTapGuideArrowheadStyle" },
        "hand_drawn": { "$ref": "#/$defs/CalloutsTapGuideHandDrawnStyle" }
      }
    },
    "CalloutsTapGuideArrowCurveStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": { "type": "string", "enum": ["tap_point", "focus_rect_center"] },
        "start_strategy": { "type": "string", "enum": ["auto_offset", "fixed_offset"] },
        "start_offset_px": { "type": "number", "exclusiveMinimum": 0 },
        "start_angle_deg": { "type": "number" },
        "curvature_px": { "type": "number" }
      }
    },
    "CalloutsTapGuideArrowheadStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "length_px": { "type": "number", "exclusiveMinimum": 0 },
        "angle_deg": { "type": "number" }
      }
    },
    "CalloutsTapGuideHandDrawnStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jitter_px": { "type": "number", "minimum": 0 },
        "wobble_px": { "type": "number", "minimum": 0 },
        "wobble_cycles": { "type": "number", "minimum": 0 },
        "passes": { "type": "integer", "minimum": 1 },
        "pass_offset_px": { "type": "number", "minimum": 0 }
      }
    },
    "CalloutsTapGuideLabelStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "text": { "type": "string" },
        "style_ref": { "type": "string", "minLength": 1 },
        "offset_px": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "padding_px": { "type": "number", "minimum": 0 },
        "bg_color_ref": { "type": "string", "minLength": 1 },
        "bg_alpha": { "type": "number", "minimum": 0, "maximum": 1 },
        "radius_px": { "type": "number", "minimum": 0 },
        "max_width_px": { "type": "number", "minimum": 50 }
      }
    },
    "BrandLayout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "card": { "$ref": "#/$defs/CardLayout" },
        "captions": { "$ref": "#/$defs/CaptionsLayout" }
      }
    },
    "CardLayout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "title_y_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "subtitle_y_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "body_y_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "autofit_padding_px": { "type": "number", "minimum": 0 }
      }
    },
    "CaptionsLayout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "y_frac": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
