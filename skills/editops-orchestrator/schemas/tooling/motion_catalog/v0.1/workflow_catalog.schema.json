{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clipops.dev/schemas/clipper/motion_workflow_catalog/v0.1",
  "title": "Clipper Motion Workflow Catalog (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "workflows"],
  "properties": {
    "schema": { "type": "string", "const": "clipper.motion_workflow_catalog.v0.1" },
    "version": { "type": "string", "minLength": 1 },
    "meta": { "type": "object", "additionalProperties": true },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Workflow" }
    }
  },
  "$defs": {
    "Workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "tags", "inputs", "outputs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/WorkflowInput" }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/WorkflowOutput" }
        },
        "template_slots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "policy": { "$ref": "#/$defs/WorkflowPolicy" }
      }
    },
    "WorkflowInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "type"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "youtube_url",
            "run_dir",
            "input_video",
            "transcript_json",
            "ios_ui_events",
            "words_signal",
            "beat_grid_signal",
            "narration_script",
            "image_assets",
            "music_track"
          ]
        },
        "required": { "type": "boolean", "default": true },
        "description": { "type": "string" }
      }
    },
    "WorkflowOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "final_video",
            "plan_timeline",
            "qa_report",
            "review_pack"
          ]
        },
        "path": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "WorkflowPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_template_instances": { "type": "integer", "minimum": 0, "maximum": 50, "default": 8 },
        "max_concurrent_templates": { "type": "integer", "minimum": 0, "maximum": 20, "default": 3 },
        "max_total_overlay_duration_ms": { "type": "integer", "minimum": 0, "default": 15000 }
      }
    }
  }
}

